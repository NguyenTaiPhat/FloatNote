# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.md text
*.yml text
*.yaml text
*.css text
*.html text
*.sh text

# Declare binary files
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.db binary
*.exe binary
*.dll binary
